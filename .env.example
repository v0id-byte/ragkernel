# LLM provider 密钥。默认走 MiniMax（见 config/settings.yaml 的 provider）。
MINIMAX_API_KEY=

# 切官方 Claude：settings.yaml 设 kind: anthropic、base_url 留空、model: claude-sonnet-5、
# api_key_env: ANTHROPIC_API_KEY，并在此填：
# ANTHROPIC_API_KEY=

# 本地私有化模型（vLLM/Ollama/Xinference，OpenAI 兼容）：settings.yaml 设 kind: openai、
# base_url: http://localhost:8000/v1、model: Qwen3-32B-AWQ、api_key_env: VLLM_API_KEY，key 任意非空：
# VLLM_API_KEY=EMPTY
